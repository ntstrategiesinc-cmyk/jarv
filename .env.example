# Copy this file to ".env" and fill in real values. ".env" is gitignored — never commit it.

# Tier 1 — the brain (required to run anything)
ANTHROPIC_API_KEY=sk-ant-...

# Tier 3 — voice (only needed once you reach Tier 3)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Tier 2 — Meta Graph API for posting photos (only needed to actually post)
# One-time setup: a Meta app (Business type), a Facebook Page, and an Instagram
# Business account linked to that Page; then a long-lived Page access token.
META_PAGE_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# Furniture pipeline — AI photo staging (only needed for stage_photo)
OPENAI_API_KEY=

# Furniture pipeline — Shopify product creation (only needed to post to your store)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
